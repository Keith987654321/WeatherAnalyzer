<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Title">Weather Analyzer</sys:String>

    <sys:String x:Key="Subtitle">
        Weather data analysis
    </sys:String>

    <sys:String x:Key="City">
        City
    </sys:String>

    <sys:String x:Key="Load">
        Load
    </sys:String>

    <sys:String x:Key="Statistics">
        Statistics
    </sys:String>

    <sys:String x:Key="Forecast">
        Forecast
    </sys:String>

    <sys:String x:Key="Chart">
        Chart
    </sys:String>

	<sys:String x:Key="AvgTemperature">
		Average Temperature
	</sys:String>

	<sys:String x:Key="MinTemperature">
		Minimum Temperature
	</sys:String>

	<sys:String x:Key="MaxTemperature">
		Maximum Temperature
	</sys:String>

	<sys:String x:Key="AvgWindSpeed">
		Average Wind Speed
	</sys:String>

    <sys:String x:Key="AvgVisibility">
        Average Visibility
    </sys:String>
    
    <sys:String x:Key="PrecAmount">
        Precipitation Amount
    </sys:String>

    <sys:String x:Key="PrecProb">
        Precipitation Probability
    </sys:String>

    <sys:String x:Key="StatusEnterCity">
        Enter a city name.
    </sys:String>

    <sys:String x:Key="StatusLoading">
        Loading data...
    </sys:String>

    <sys:String x:Key="StatusError">
        Error
    </sys:String>

    <sys:String x:Key="StatusCompleted">
        Data loaded successfully.
    </sys:String>

    <sys:String x:Key="ColumnDate">Date</sys:String>
    <sys:String x:Key="ColumnPeriod">Period</sys:String>
    <sys:String x:Key="ColumnTemperature">Temp.</sys:String>
    <sys:String x:Key="ColumnWind">Wind</sys:String>
    <sys:String x:Key="ColumnVisibility">Visibility</sys:String>
    <sys:String x:Key="ColumnRain">Rain</sys:String>
    <sys:String x:Key="ColumnProbability">Probability</sys:String>
</ResourceDictionary>