<Window x:Class="WeatherAnalyzer.Views.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
    Title="Weather Analyzer"
    Height="875"
    Width="1000"
    MinHeight="700"
    MinWidth="800"
    Background="{DynamicResource WindowBackgroundBrush}">

    <Grid Margin="20">

        <Grid.RowDefinitions>

            <RowDefinition Height="Auto"/>
            <!-- Заголовок -->

            <RowDefinition Height="Auto"/>
            <!-- Поиск -->

            <RowDefinition Height="Auto"/>
            <!-- Статус -->

            <RowDefinition Height="Auto"/>
            <!-- Статистика -->

            <RowDefinition Height="*"/>
            <!-- Таблица + график -->

        </Grid.RowDefinitions>

        <!-- Заголовок -->

        <Grid Grid.Row="0" Margin="0,0,0,20">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel>

                <TextBlock
                    HorizontalAlignment="Center"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Foreground="{DynamicResource ForegroundBrush}"
                    Text="Weather Analyzer"/>

                <TextBlock
                    HorizontalAlignment="Center"
                    Margin="0,5,0,0"
                    Foreground="{DynamicResource SecondaryForegroundBrush}"
                    Text="{DynamicResource Subtitle}"/>

            </StackPanel>

            <StackPanel
                Orientation="Horizontal"
                HorizontalAlignment="Right">

                <ComboBox
                    Width="120"
                    Height="25"
                    Margin="0,0,5,0"
                    ItemsSource="{Binding AvailableLanguages}"
                    SelectedItem="{Binding SelectedLanguage}"/>
                
                <ComboBox
                    Width="120"
                    Height="25"
                    ItemsSource="{Binding AvailableThemes}"
                    SelectedItem="{Binding SelectedTheme}"/>
            </StackPanel>



        </Grid>

        <!-- Поиск -->

        <StackPanel
        Grid.Row="1"
        Margin="0,0,0,20">

            <TextBlock
            Margin="0,0,0,5"
            FontWeight="SemiBold"
            Text="{DynamicResource City}"/>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Height="32"
                    Margin="0,0,10,0"
                    VerticalContentAlignment="Center"
                    Background="{DynamicResource ControlBackgroundBrush}"
                    Foreground="{DynamicResource ControlForegroundBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"/>

                <Button
                    Grid.Column="1"
                    Width="120"
                    Background="{DynamicResource AccentBrush}"
                    Foreground="White"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Content="{DynamicResource Load}"
                    Command="{Binding LoadWeatherCommand}"/>

            </Grid>

        </StackPanel>

        <!-- Статус -->

        <TextBlock
        Grid.Row="2"
        Margin="0,0,0,20"
        Foreground="{DynamicResource ForegroundBrush}"
        Text="{Binding Status}"/>


        <!-- Статистика -->

        <Border
            Grid.Row="3"
            Margin="0,0,0,20"
            Padding="15"
            Background="{DynamicResource CardBackgroundBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            CornerRadius="8">

            <DockPanel>

                <TextBlock
                    DockPanel.Dock="Top"
                    Margin="0,0,0,15"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="{DynamicResource Statistics}"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Margin="0,4" Text="{DynamicResource AvgTemperature}"/>
                    <TextBlock Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding AverageTemperature, StringFormat={}{0:F1} °C}"/>

                    <TextBlock Grid.Row="1"
                    Margin="0,4"
                    Text="{DynamicResource MinTemperature}"/>
                    <TextBlock Grid.Row="1"
                    Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding MinimumTemperature, StringFormat={}{0:F1} °C}"/>

                    <TextBlock Grid.Row="2"
                    Margin="0,4"
                    Text="{DynamicResource MaxTemperature}"/>
                    <TextBlock Grid.Row="2"
                    Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding MaximumTemperature, StringFormat={}{0:F1} °C}"/>

                    <TextBlock Grid.Row="3"
                    Margin="0,4"
                    Text="{DynamicResource AvgWindSpeed}"/>
                    <TextBlock Grid.Row="3"
                    Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding AverageWindSpeed, StringFormat={}{0:F1} км/ч}"/>

                    <TextBlock Grid.Row="4"
                    Margin="0,4"
                    Text="{DynamicResource AvgVisibility}"/>
                    <TextBlock Grid.Row="4"
                    Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding AverageVisibility, StringFormat={}{0:F1} км}"/>

                    <TextBlock Grid.Row="5"
                    Margin="0,4"
                    Text="{DynamicResource PrecAmount}"/>
                    <TextBlock Grid.Row="5"
                    Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding AveragePrecipitationAmount, StringFormat={}{0:F1} мм}"/>

                    <TextBlock Grid.Row="6"
                    Margin="0,4"
                    Text="{DynamicResource PrecProb}"/>
                    <TextBlock Grid.Row="6"
                    Grid.Column="1"
                    Margin="0,4"
                    Text="{Binding AveragePrecipitationProbability, StringFormat={}{0:F1} %}"/>

                </Grid>

            </DockPanel>

        </Border>

        <!-- Таблица + график -->

        <Grid Grid.Row="4">

            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Таблица -->

            <Border
    Grid.Column="0"
    Margin="0,0,10,0"
    Padding="10"
    Background="{DynamicResource CardBackgroundBrush}"
    BorderBrush="{DynamicResource BorderBrush}"
    BorderThickness="1"
    CornerRadius="8">

                <DockPanel>

                    <TextBlock
            DockPanel.Dock="Top"
            Margin="0,0,0,10"
            FontSize="18"
            FontWeight="SemiBold"
            Text="{DynamicResource Forecast}"/>

                    <DataGrid
            AutoGenerateColumns="False"
            ColumnWidth="*"
            IsReadOnly="True"
            CanUserAddRows="False"
            CanUserDeleteRows="False"
            CanUserResizeRows="False"
            HeadersVisibility="Column"
            SelectionMode="Single"
            ScrollViewer.VerticalScrollBarVisibility="Auto"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            ItemsSource="{Binding WeatherRecords}">

                        <DataGrid.Columns>

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnDate}"
                        Binding="{Binding Date, StringFormat={}{0:dd.MM.yyyy}}" />

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnPeriod}"
                        Binding="{Binding PeriodName}" />

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnTemperature}"
                        Binding="{Binding Temperature, StringFormat={}{0} °C}" />

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnWind}"
                        Binding="{Binding WindSpeed, StringFormat={}{0} км/ч}" />

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnVisibility}"
                        Binding="{Binding Visibility, StringFormat={}{0} км}" />

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnRain}"
                        Binding="{Binding PrecipitationAmount, StringFormat={}{0:F1} мм}" />

                            <DataGridTextColumn
                        Header="{DynamicResource ColumnProbability}"
                        Binding="{Binding PrecipitationProbability, StringFormat={}{0}%}" />

                        </DataGrid.Columns>
                    </DataGrid>

                </DockPanel>

            </Border>

            <!-- График -->

            <Border
    Grid.Column="1"
    Margin="10,0,0,0"
    Padding="10"
    Background="{DynamicResource CardBackgroundBrush}"
    BorderBrush="{DynamicResource BorderBrush}"
    BorderThickness="1"
    CornerRadius="8">

                <Grid>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock
                        Grid.Row="0"
                        Margin="0,0,0,10"
                        FontSize="18"
                        FontWeight="SemiBold"
                        Text="{DynamicResource Chart}"/>

                    <ComboBox
                        Grid.Row="1"
                        Width="220"
                        Margin="0,0,0,10"
                        HorizontalAlignment="Left"
                        ItemsSource="{Binding AvailableCharts}"
                        SelectedItem="{Binding SelectedChart}"
                        Background="{DynamicResource ControlBackgroundBrush}"
                        Foreground="{DynamicResource ControlForegroundBrush}"
                        BorderBrush="{DynamicResource BorderBrush}"/>

                    <lvc:CartesianChart
                        Grid.Row="2"
                        Margin="5"
                        Series="{Binding TemperatureSeries}"
                        XAxes="{Binding XAxes}"
                        YAxes="{Binding YAxes}"/>

                </Grid>

            </Border>

        </Grid>

    </Grid>

</Window>