<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Title">Weather Analyzer</sys:String>

    <sys:String x:Key="Subtitle">
        Анализ погодных данных
    </sys:String>

    <sys:String x:Key="City">
        Город
    </sys:String>

    <sys:String x:Key="Load">
        Загрузить
    </sys:String>

    <sys:String x:Key="Statistics">
        Статистика
    </sys:String>

    <sys:String x:Key="Forecast">
        Прогноз
    </sys:String>

    <sys:String x:Key="Chart">
        График
    </sys:String>

	<sys:String x:Key="AvgTemperature">
		Средняя Температура
	</sys:String>

	<sys:String x:Key="MinTemperature">
		Минимальная Температура
	</sys:String>

	<sys:String x:Key="MaxTemperature">
		Максимальная Температура
	</sys:String>

	<sys:String x:Key="AvgWindSpeed">
		Средняя Скорость Ветра
	</sys:String>

	<sys:String x:Key="AvgVisibility">
		Средняя Видимость
	</sys:String>

	<sys:String x:Key="PrecAmount">
		Количество Осадков
	</sys:String>

	<sys:String x:Key="PrecProb">
		Вероятность Осадков
	</sys:String>

    <sys:String x:Key="StatusEnterCity">
        Введите название города.
    </sys:String>

    <sys:String x:Key="StatusLoading">
        Загрузка данных...
    </sys:String>

    <sys:String x:Key="StatusError">
        Ошибка
    </sys:String>

    <sys:String x:Key="StatusCompleted">
        Данные успешно загружены.
    </sys:String>

    <sys:String x:Key="ColumnDate">Дата</sys:String>
    <sys:String x:Key="ColumnPeriod">Период</sys:String>
    <sys:String x:Key="ColumnTemperature">Темп.</sys:String>
    <sys:String x:Key="ColumnWind">Ветер</sys:String>
    <sys:String x:Key="ColumnVisibility">Видимость</sys:String>
    <sys:String x:Key="ColumnRain">Осадки</sys:String>
    <sys:String x:Key="ColumnProbability">Вероятность</sys:String>

</ResourceDictionary>