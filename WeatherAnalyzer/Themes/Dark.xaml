<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

	<!-- Основной фон -->
	<SolidColorBrush
        x:Key="WindowBackgroundBrush"
        Color="#202020"/>

	<!-- Фон карточек -->
	<SolidColorBrush
        x:Key="CardBackgroundBrush"
        Color="#2B2B2B"/>

	<!-- Основной текст -->
	<SolidColorBrush
        x:Key="ForegroundBrush"
        Color="White"/>

	<!-- Вторичный текст -->
	<SolidColorBrush
        x:Key="SecondaryForegroundBrush"
        Color="#C8C8C8"/>

	<!-- Границы -->
	<SolidColorBrush
        x:Key="BorderBrush"
        Color="#505050"/>

	<SolidColorBrush
		x:Key="ControlBackgroundBrush"
		Color="#3A3A3A"/>

	<SolidColorBrush
		x:Key="ControlForegroundBrush"
		Color="White"/>

	<SolidColorBrush
		x:Key="AccentBrush"
		Color="#3399FF"/>

	<SolidColorBrush
    x:Key="DataGridHeaderBackgroundBrush"
    Color="#404040"/>

	<SolidColorBrush
		x:Key="DataGridRowBackgroundBrush"
		Color="#2B2B2B"/>

	<SolidColorBrush
		x:Key="DataGridSelectedRowBrush"
		Color="#295A8F"/>

	<SolidColorBrush
		x:Key="DataGridGridBrush"
		Color="#555555"/>
	<Style TargetType="DataGrid">

		<Setter Property="Background"
            Value="{DynamicResource DataGridRowBackgroundBrush}"/>

		<Setter Property="Foreground"
            Value="{DynamicResource ForegroundBrush}"/>

		<Setter Property="BorderBrush"
            Value="{DynamicResource BorderBrush}"/>

		<Setter Property="GridLinesVisibility"
            Value="All"/>

		<Setter Property="HorizontalGridLinesBrush"
            Value="{DynamicResource DataGridGridBrush}"/>

		<Setter Property="VerticalGridLinesBrush"
            Value="{DynamicResource DataGridGridBrush}"/>

		<Setter Property="RowBackground"
            Value="{DynamicResource DataGridRowBackgroundBrush}"/>

		<Setter Property="AlternatingRowBackground"
            Value="{DynamicResource CardBackgroundBrush}"/>
	</Style>

	<Style TargetType="DataGridColumnHeader">

		<Setter Property="Background"
            Value="{DynamicResource DataGridHeaderBackgroundBrush}"/>

		<Setter Property="Foreground"
            Value="{DynamicResource ForegroundBrush}"/>

		<Setter Property="BorderBrush"
            Value="{DynamicResource BorderBrush}"/>

		<Setter Property="FontWeight"
            Value="SemiBold"/>

	</Style>

	<Style TargetType="DataGridRow">

		<Setter Property="Background"
            Value="{DynamicResource DataGridRowBackgroundBrush}"/>

		<Setter Property="Foreground"
            Value="{DynamicResource ForegroundBrush}"/>

	</Style>

	<Style TargetType="TextBlock">
		<Setter Property="Foreground"
				Value="{DynamicResource ForegroundBrush}"/>
	</Style>

	<SolidColorBrush
    x:Key="ComboBoxPopupBackgroundBrush"
    Color="#353535"/>

	<SolidColorBrush
	x:Key="ComboBoxItemHoverBrush"
	Color="#4A6484"/>

	<Style TargetType="ComboBox">
		<Setter Property="Background"
				Value="{DynamicResource ControlBackgroundBrush}"/>

		<Setter Property="Foreground"
				Value="{DynamicResource ComboBoxForegroundBrush}"/>

		<Setter Property="BorderBrush"
				Value="{DynamicResource BorderBrush}"/>

		<Setter Property="Padding"
				Value="6,3"/>
	</Style>

	<Style TargetType="ComboBoxItem">
		<Setter Property="Foreground"
				Value="{DynamicResource ComboBoxForegroundBrush}"/>

		<Setter Property="Background"
				Value="{DynamicResource ComboBoxPopupBackgroundBrush}"/>
	</Style>

	<SolidColorBrush
    x:Key="ComboBoxForegroundBrush"
    Color="#4DA3FF"/>
</ResourceDictionary>