<Window x:Class="WeatherAnalyzer.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Weather Analyzer"
        Height="650"
        Width="900"
        MinHeight="600"
        MinWidth="800">

    <Grid Margin="20">

        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Заголовок -->

        <StackPanel
            Grid.Row="0"
            Margin="0,0,0,20">

            <TextBlock
                HorizontalAlignment="Center"
                FontSize="28"
                FontWeight="SemiBold"
                Text="Weather Analyzer"/>

            <TextBlock
                HorizontalAlignment="Center"
                Margin="0,5,0,0"
                Foreground="Gray"
                Text="Анализ погодных данных"/>

        </StackPanel>

        <!-- Поиск -->

        <StackPanel
            Grid.Row="1"
            Margin="0,0,0,20">

            <TextBlock
                Margin="0,0,0,5"
                FontWeight="SemiBold"
                Text="Город"/>

            <Grid>

                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBox
                    Grid.Column="0"
                    Height="32"
                    Margin="0,0,10,0"
                    VerticalContentAlignment="Center"
                    Text="{Binding City, UpdateSourceTrigger=PropertyChanged}"/>

                <Button
                    Grid.Column="1"
                    Width="120"
                    Content="Загрузить"
                    Command="{Binding LoadWeatherCommand}"/>

            </Grid>

        </StackPanel>

        <!-- Статистика -->

        <Border
            Grid.Row="2"
            Margin="0,0,0,20"
            Padding="15"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="8">

            <DockPanel>

                <TextBlock
                    DockPanel.Dock="Top"
                    Margin="0,0,0,15"
                    FontSize="18"
                    FontWeight="SemiBold"
                    Text="Статистика"/>

                <Grid>

                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Margin="0,4" Text="Средняя температура"/>
                    <TextBlock Grid.Column="1" Margin="0,4" Text="{Binding AverageTemperature, StringFormat={}{0:F1} °C}"/>

                    <TextBlock Grid.Row="1" Margin="0,4" Text="Минимальная температура"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,4" Text="{Binding MinimumTemperature, StringFormat={}{0:F1} °C}"/>

                    <TextBlock Grid.Row="2" Margin="0,4" Text="Максимальная температура"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,4" Text="{Binding MaximumTemperature, StringFormat={}{0:F1} °C}"/>

                    <TextBlock Grid.Row="3" Margin="0,4" Text="Средняя влажность"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,4" Text="{Binding AverageHumidity, StringFormat={}{0:F1} %}"/>

                    <TextBlock Grid.Row="4" Margin="0,4" Text="Среднее давление"/>
                    <TextBlock Grid.Row="4" Grid.Column="1" Margin="0,4" Text="{Binding AveragePressure, StringFormat={}{0:F1} гПа}"/>

                    <TextBlock Grid.Row="5" Margin="0,4" Text="Средняя скорость ветра"/>
                    <TextBlock Grid.Row="5" Grid.Column="1" Margin="0,4" Text="{Binding AverageWindSpeed, StringFormat={}{0:F1} м/c}"/>

                </Grid>

            </DockPanel>

        </Border>

        <!-- Область графика -->

        <Border
            Grid.Row="3"
            Padding="10"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="8">

            <TextBlock
                HorizontalAlignment="Center"
                VerticalAlignment="Center"
                FontSize="18"
                Foreground="Gray"
                Text="Здесь будет отображаться график температуры"/>

        </Border>

    </Grid>

</Window>