<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib">

    <sys:String x:Key="Title">Weather Analyzer</sys:String>

    <sys:String x:Key="Subtitle">
        Weather data analysis
    </sys:String>

    <sys:String x:Key="City">
        City
    </sys:String>

    <sys:String x:Key="Load">
        Load
    </sys:String>

    <sys:String x:Key="Statistics">
        Statistics
    </sys:String>

    <sys:String x:Key="Forecast">
